install.packages("modelsummary")
library(modelsummary)
model <- lm(galamsey_support ~
poverty_index +
env_concern +
poverty_index * env_concern +
water_satisfaction +
factor(urban) +
factor(employment) +
education +
factor(region) +
factor(party_id),
data = r7_reg)
