r9_data <- read_sav("C:\\Users\\Yasmin Lukman\\Downloads\\afrobarometer_release-dataset_gha_r9_en_2023-04-01.sav")
r7_data1 <- r7_data %>% mutate(
across(c(Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), ~ifelse(. < 0, NA, .)),  poverty_index = rowMeans(select(., Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), na.rm = TRUE),
galamsey_support = ifelse(Q83A_GHA < 0, NA, Q83A_GHA) )
r7_data1 <- r7_data1 %>%
mutate(
poverty_cat = cut(
poverty_index,
breaks = c(0, 1, 2, 3, 4),
labels = c("Low", "Moderate", "High", "Very High"),
include.lowest = TRUE
)
)
r7_data1 <- r7_data %>% mutate(
across(c(Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), ~ifelse(. < 0, NA, .)),  poverty_index = rowMeans(select(., Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), na.rm = TRUE),
galamsey_support = ifelse(Q83A_GHA < 0, NA, Q83A_GHA) )
r7_data1 <- r7_data1 %>%
mutate(
poverty_cat = cut(
poverty_index,
breaks = c(0, 1, 2, 3, 4),
labels = c("Low", "Moderate", "High", "Very High"),
include.lowest = TRUE
)
)
ggplot(r7_data1, aes(x = poverty_cat, fill = factor(galamsey_support))) +
geom_bar(position = "fill") +
labs(
title = "Proportion of Support for Galamsey by Poverty Level",
x = "Level of Lived Poverty",
y = "Proportion",
fill = "Support for Galamsey"
) +
theme_minimal()
