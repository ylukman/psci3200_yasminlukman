ggplot(r7_data1, aes(x = poverty_cat, fill = factor(galamsey_support))) +
geom_bar(position = "dodge") +
labs(
title = "Lived Poverty and Support for Illegal Mining (Galamsey)",
x = "Level of Lived Poverty",
y = "Number of Respondents",
fill = "Support for Galamsey",
) +
scale_fill_discrete(labels = c(
"1" = "Agree strongly with 1",
"2" = "Agree with 1",
"3" = "Agree with 2",
"4" = "Agree strongly with 2",
"5" = "Agree with neither"
), na.translate = FALSE) +
theme_minimal()
ggplot(r7_data1, aes(x = factor(galamsey_support), fill = factor(env_concern))) +
geom_bar(position = "dodge") +
labs(
title = "Support for Illegal Mining (Galamsey) and Environmental Concern",
x = "Support for Galamsey",
y = "Number of Respondents",
fill = "Environmental Concern (Q76)"
) +
scale_fill_discrete(labels = c(
"0" = "Climate change does not need to be stopped",
"1" = "Yes,ordinary Ghanaians cannot do anything",
"2" = "Yes,ordinary Ghanaians can do a little",
"3" = "Yes,ordinary Ghanaians can do a lot"
), na.translate=FALSE) +
theme_minimal()
r7_reg = r7_data %>%
mutate( across(c(Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), ~ifelse(. < 0, NA, .)),
poverty_index = rowMeans(select(., Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), na.rm = TRUE),
galamsey_support = ifelse(Q83A_GHA < 0| Q83A_GHA >5, NA, Q83A_GHA),
env_concern = ifelse(Q76 < 0| Q76>3, NA, Q76),
water_satisfaction = ifelse(Q56I <0 | Q56I <4, NA, Q56I),
urban = ifelse(URBRUR <0, NA, URBRUR),
employment = ifelse(Q94 <0 | Q94 >3, NA, Q94),
education= ifelse(Q97 <0 | Q97 > 9, NA, Q97),
region = ifelse(REGION <0, NA, REGION),
party_id = ifelse(Q88B<0 |Q88B > 9995, NA, Q88B)
)
r7_reg
library(modelsummary)
model <- lm(galamsey_support ~
poverty_index +
env_concern +
poverty_index * env_concern +
water_satisfaction +
factor(urban) +
factor(employment) +
education +
factor(region) +
factor(party_id),
data = r7_reg)
modelsummary(model,
title = "Regression Model: Predictors of Support for Illegal Mining (Galamsey)",
coef_rename = c(
"(Intercept)" = "Intercept",
"poverty_index" = "Lived Poverty Index",
"env_concern" = "Environmental Concern",
"poverty_index:env_concern" = "Poverty × Environmental Concern (Interaction)",
"water_satisfaction" = "Water Satisfaction",
"education" = "Education"
),
coef_omit = "factor(region)|factor(party_id)|factor(employment)|factor(urban)",
stars = c("*" = 0.05, "**" = 0.01, "***" = 0.001),
statistic = "std.error",
fmt = 3,
gof_map = c("nobs", "r.squared", "adj.r.squared"),
notes = c(
"Standard errors in parentheses.",
"* p < 0.05, ** p < 0.01, *** p < 0.001",
"Factor controls included for urban/rural, employment, region, and party ID.",
"Data: Afrobarometer Round 7 Ghana Survey"
)
)
