galamsey_support = ifelse(Q83A_GHA < 0, NA, Q83A_GHA). )
r7_data1 <- r7_data %>% mutate(
across(c(Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), ~ifelse(. < 0, NA, .)),  poverty_index = rowMeans(select(., Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), na.rm = TRUE),
galamsey_support = ifelse(Q83A_GHA < 0, NA, Q83A_GHA),
