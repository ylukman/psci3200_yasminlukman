r7_data1 <- r7_data %>% mutate(
across(c(Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), ~ifelse(. < 0, NA, .)),  poverty_index = rowMeans(select(., Q8A, Q8B, Q8C, Q8D, Q8E, Q8F), na.rm = TRUE),
galamsey_support = ifelse(Q83A_GHA < 0, NA, Q83A_GHA),
env_concern = ifelse(Q71 < 0, NA, Q71) )
summary_df <- data.frame(
Variable = c("Galamsey Support", "Lived Poverty Index", "Environmental Concern"),
Mean     = c(mean(r7_data1$galamsey_support, na.rm = TRUE),
mean(r7_data1$poverty_index,    na.rm = TRUE),
mean(r7_data1$env_concern,      na.rm = TRUE)),
Min      = c(min(r7_data1$galamsey_support,  na.rm = TRUE),
min(r7_data1$poverty_index,      na.rm = TRUE),
min(r7_data1$env_concern,        na.rm = TRUE)),
Max      = c(max(r7_data1$galamsey_support,  na.rm = TRUE),
max(r7_data1$poverty_index,      na.rm = TRUE),
max(r7_data1$env_concern,        na.rm = TRUE)),
SD       = c(sd(r7_data1$galamsey_support,   na.rm = TRUE),
sd(r7_data1$poverty_index,       na.rm = TRUE),
sd(r7_data1$env_concern,         na.rm = TRUE))
)
summary_df <- summary_df %>%
mutate(across(where(is.numeric), ~ round(., 2)))
